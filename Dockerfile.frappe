FROM frappe/bench:latest

USER root

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
    python3-dev \
    build-essential \
    gcc \
    g++ \
    pkg-config \
    libffi-dev \
    libssl-dev \
    libmariadb-dev \
    mariadb-client \
    redis-server \
    curl \
    git \
    nodejs \
    npm \
    ca-certificates \
    && npm install -g yarn@1.22.22 \
    && rm -rf /var/lib/apt/lists/*

USER frappe